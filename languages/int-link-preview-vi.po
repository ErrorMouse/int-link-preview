msgid "Displays a preview tooltip when hovering over internal links in posts."
msgstr "Hiển thị chú thích xem trước khi di chuột qua các liên kết nội bộ trong bài viết."

msgid "Content type to display"
msgstr "Loại nội dung cần hiển thị"

msgid "Excerpt"
msgstr "Trích đoạn"

msgid "Post Content"
msgstr "Nội dung bài đăng"

msgid "Number of words to display"
msgstr "Số lượng từ cần hiển thị"

msgid "Default is 80 words."
msgstr "Mặc định là 80 từ."

msgid "Button text"
msgstr "Văn bản nút"

msgid "Read more"
msgstr "Đọc thêm"

msgid "Text to display on the link button inside tooltip."
msgstr "Văn bản hiển thị trên nút liên kết bên trong chú thích công cụ."

msgid "Loading preview..."
msgstr "Đang tải..."

msgid "Post not found"
msgstr "Không tìm thấy bài đăng"

msgid "Donate to support this plugin"
msgstr "Hãy quyên góp để hỗ trợ plugin này"

msgid "Donate"
msgstr "Ủng hộ"
